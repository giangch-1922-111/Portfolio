<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cao Hương Giang — Business Analyst</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #FAF6F0;
    --cream-dark: #F0E6D3;
    --amber: #C17F4A;
    --amber-light: #D9A06A;
    --amber-pale: #F5DFC0;
    --brown-dark: #2C1810;
    --brown-mid: #5C3D2E;
    --brown-muted: #8C7B6E;
    --brown-faint: #C4B5A8;
    --white: #FFFFFF;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--brown-dark);
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 5%;
    height: 64px;
    background: rgba(250,246,240,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--cream-dark);
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: var(--brown-dark);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a {
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brown-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--amber); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex; align-items: center;
    padding: 80px 5% 0;
    position: relative;
    overflow: hidden;
  }
  .hero-bg-text {
    position: absolute;
    top: 50%; right: -2%;
    transform: translateY(-50%);
    font-family: 'Playfair Display', serif;
    font-size: clamp(8rem, 18vw, 18rem);
    font-weight: 700;
    color: var(--cream-dark);
    opacity: 0.5;
    user-select: none;
    pointer-events: none;
    line-height: 1;
    white-space: nowrap;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 6rem;
    align-items: center;
    width: 100%;
    max-width: 1200px;
  }
  .hero-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 1.5rem;
    display: flex; align-items: center; gap: 0.8rem;
  }
  .hero-eyebrow::before {
    content: '';
    display: inline-block;
    width: 32px; height: 1px;
    background: var(--amber);
  }
  .hero-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--brown-dark);
    margin-bottom: 0.3rem;
  }
  .hero-name em {
    font-style: italic;
    color: var(--amber);
  }
  .hero-role {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    font-weight: 400;
    font-style: italic;
    color: var(--brown-muted);
    margin-bottom: 2rem;
  }
  .hero-summary {
    font-size: 1rem;
    color: var(--brown-mid);
    max-width: 560px;
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }
  .hero-cta {
    display: flex; gap: 1rem; flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.85rem 2rem;
    background: var(--amber);
    color: var(--white);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.2s, transform 0.2s;
  }
  .btn-primary:hover { background: var(--brown-mid); transform: translateY(-2px); }
  .btn-outline {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.85rem 2rem;
    border: 1.5px solid var(--brown-faint);
    color: var(--brown-mid);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-outline:hover { border-color: var(--amber); color: var(--amber); }

  /* Hero card */
  .hero-card {
    background: var(--white);
    border: 1px solid var(--cream-dark);
    border-radius: 12px;
    padding: 2.5rem;
    position: relative;
  }
  .hero-card-accent {
    position: absolute; top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--amber), var(--amber-light));
    border-radius: 12px 12px 0 0;
  }
  .hero-avatar {
    width: 80px; height: 80px;
    border-radius: 50%;
    background: var(--cream-dark);
    margin-bottom: 1.5rem;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: var(--amber);
    font-weight: 700;
    overflow: hidden;
  }
  .hero-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .info-row {
    display: flex; align-items: flex-start; gap: 0.75rem;
    margin-bottom: 0.9rem;
    font-size: 0.88rem;
    color: var(--brown-mid);
  }
  .info-row .icon { font-size: 1rem; flex-shrink: 0; margin-top: 0.05rem; }
  .info-row a { color: var(--amber); text-decoration: none; }
  .info-row a:hover { text-decoration: underline; }
  .hero-stats {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--cream-dark);
  }
  .stat { text-align: center; }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--amber);
    line-height: 1;
    display: block;
  }
  .stat-label {
    font-size: 0.72rem;
    color: var(--brown-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: 0.3rem;
    display: block;
  }

  /* ── SECTION BASE ── */
  section { padding: 100px 5%; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 0.8rem;
    display: flex; align-items: center; gap: 0.8rem;
  }
  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--cream-dark);
    max-width: 80px;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--brown-dark);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }
  .section-title em { font-style: italic; color: var(--amber); }
  .section-sub {
    font-size: 1rem;
    color: var(--brown-muted);
    max-width: 500px;
    margin-bottom: 4rem;
    line-height: 1.7;
  }

  /* ── GROWTH TIMELINE (năm học) ── */
  .growth-section { background: var(--brown-dark); }
  .growth-section .section-label { color: var(--amber-light); }
  .growth-section .section-title { color: var(--white); }
  .growth-section .section-sub { color: var(--brown-faint); }

  .timeline-years {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5px;
    background: var(--brown-mid);
    border-radius: 12px;
    overflow: hidden;
  }
  .year-card {
    background: #1E0F08;
    padding: 2.5rem 2rem;
    position: relative;
    transition: background 0.3s;
    cursor: default;
  }
  .year-card:hover { background: #2A1510; }
  .year-card-top {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1.5rem;
  }
  .year-badge {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    font-weight: 700;
    color: var(--amber);
    opacity: 0.25;
    line-height: 1;
  }
  .year-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--amber-light);
    text-align: right;
  }
  .year-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .year-items { list-style: none; }
  .year-items li {
    font-size: 0.85rem;
    color: var(--brown-faint);
    padding: 0.45rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    line-height: 1.5;
    display: flex; align-items: flex-start; gap: 0.6rem;
  }
  .year-items li:last-child { border-bottom: none; }
  .year-items li::before {
    content: '→';
    color: var(--amber);
    flex-shrink: 0;
    font-size: 0.75rem;
    margin-top: 0.1rem;
  }
  .year-award {
    margin-top: 1.2rem;
    padding: 0.6rem 0.9rem;
    background: rgba(193,127,74,0.15);
    border-left: 2px solid var(--amber);
    border-radius: 0 4px 4px 0;
    font-size: 0.78rem;
    color: var(--amber-light);
    line-height: 1.5;
  }

  /* ── EXPERIENCE ── */
  .exp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .exp-card {
    background: var(--white);
    border: 1px solid var(--cream-dark);
    border-radius: 10px;
    padding: 2.5rem;
    position: relative;
    transition: box-shadow 0.3s, transform 0.3s;
  }
  .exp-card:hover {
    box-shadow: 0 12px 40px rgba(44,24,16,0.1);
    transform: translateY(-4px);
  }
  .exp-card-accent {
    position: absolute; top: 0; left: 2.5rem; right: 2.5rem;
    height: 3px;
    background: linear-gradient(90deg, var(--amber), transparent);
    border-radius: 0 0 3px 3px;
  }
  .exp-period {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: var(--amber);
    margin-bottom: 0.8rem;
  }
  .exp-company {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--brown-dark);
    margin-bottom: 0.2rem;
  }
  .exp-role {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--brown-muted);
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--cream-dark);
  }
  .exp-items { list-style: none; }
  .exp-items li {
    font-size: 0.88rem;
    color: var(--brown-mid);
    padding: 0.5rem 0;
    display: flex; align-items: flex-start; gap: 0.8rem;
    border-bottom: 1px solid var(--cream-dark);
    line-height: 1.6;
  }
  .exp-items li:last-child { border-bottom: none; }
  .exp-items li .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--amber);
    flex-shrink: 0;
    margin-top: 0.55rem;
  }

  /* ── PROJECTS ── */
  .projects-section { background: var(--cream-dark); }
  .proj-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 2rem; }
  .proj-card {
    background: var(--white);
    border-radius: 12px;
    padding: 0;
    overflow: hidden;
    border: 1px solid rgba(193,127,74,0.15);
    transition: box-shadow 0.3s, transform 0.3s;
  }
  .proj-card:hover {
    box-shadow: 0 16px 50px rgba(44,24,16,0.12);
    transform: translateY(-6px);
  }
  .proj-header {
    padding: 2rem 2.5rem 1.5rem;
    background: linear-gradient(135deg, var(--brown-dark) 0%, var(--brown-mid) 100%);
    position: relative;
    overflow: hidden;
  }
  .proj-header::after {
    content: '';
    position: absolute;
    bottom: -30px; right: -30px;
    width: 120px; height: 120px;
    border-radius: 50%;
    background: rgba(193,127,74,0.1);
  }
  .proj-tag {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--amber-light);
    border: 1px solid rgba(193,127,74,0.4);
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
    margin-bottom: 0.8rem;
  }
  .proj-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 0.4rem;
  }
  .proj-sub {
    font-size: 0.82rem;
    color: var(--brown-faint);
  }
  .proj-body { padding: 2rem 2.5rem; }
  .proj-desc {
    font-size: 0.9rem;
    color: var(--brown-mid);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }
  .proj-highlights { list-style: none; }
  .proj-highlights li {
    font-size: 0.85rem;
    color: var(--brown-mid);
    padding: 0.4rem 0;
    display: flex; align-items: flex-start; gap: 0.7rem;
    line-height: 1.5;
  }
  .proj-highlights li::before {
    content: '◆';
    color: var(--amber);
    font-size: 0.5rem;
    flex-shrink: 0;
    margin-top: 0.45rem;
  }
  .proj-award {
    margin-top: 1.2rem;
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.7rem 1rem;
    background: var(--amber-pale);
    border-radius: 6px;
    font-size: 0.82rem;
    color: var(--brown-mid);
    font-weight: 500;
  }
  .proj-award .trophy { font-size: 1rem; }
  .proj-modules {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    margin-top: 1.2rem;
  }
  .module-tag {
    font-size: 0.75rem;
    padding: 0.3rem 0.75rem;
    background: var(--cream-dark);
    color: var(--brown-mid);
    border-radius: 20px;
    font-weight: 500;
    white-space: nowrap;
  }
  .proj-link {
    display: inline-flex; align-items: center; gap: 0.4rem;
    margin-top: 1.2rem;
    font-size: 0.8rem;
    color: var(--amber);
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 0.05em;
  }
  .proj-link:hover { text-decoration: underline; }

  /* ── SKILLS ── */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .skill-group {
    background: var(--white);
    border: 1px solid var(--cream-dark);
    border-radius: 10px;
    padding: 2rem;
  }
  .skill-group-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 1.5rem;
    display: flex; align-items: center; gap: 0.6rem;
  }
  .skill-group-title .icon { font-size: 1rem; }
  .skill-item { margin-bottom: 1.2rem; }
  .skill-item:last-child { margin-bottom: 0; }
  .skill-name-row {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 0.4rem;
  }
  .skill-name {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--brown-dark);
  }
  .skill-level {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--brown-muted);
  }
  .skill-bar {
    height: 4px;
    background: var(--cream-dark);
    border-radius: 2px;
    overflow: hidden;
  }
  .skill-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--amber), var(--amber-light));
    border-radius: 2px;
    transition: width 1s ease;
  }
  .skill-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .skill-tag {
    font-size: 0.78rem;
    padding: 0.35rem 0.8rem;
    background: var(--cream-dark);
    color: var(--brown-mid);
    border-radius: 4px;
    font-weight: 500;
    transition: background 0.2s;
  }
  .skill-tag:hover { background: var(--amber-pale); }

  /* ── AWARDS ── */
  .awards-section { background: var(--brown-dark); }
  .awards-section .section-label { color: var(--amber-light); }
  .awards-section .section-title { color: var(--white); }
  .awards-section .section-sub { color: var(--brown-faint); }
  .awards-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .award-card {
    padding: 2rem;
    border: 1px solid rgba(193,127,74,0.2);
    border-radius: 10px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, background 0.3s;
  }
  .award-card:hover {
    border-color: var(--amber);
    background: rgba(193,127,74,0.05);
  }
  .award-rank {
    font-family: 'Playfair Display', serif;
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--amber);
    opacity: 0.2;
    line-height: 1;
    position: absolute;
    top: 1rem; right: 1.5rem;
  }
  .award-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: var(--amber-light);
    margin-bottom: 1rem;
  }
  .award-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--white);
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }
  .award-desc {
    font-size: 0.82rem;
    color: var(--brown-faint);
    line-height: 1.6;
  }

  /* ── EDUCATION ── */
  .edu-card {
    background: var(--white);
    border: 1px solid var(--cream-dark);
    border-radius: 12px;
    padding: 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .edu-period {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: var(--amber);
    margin-bottom: 0.8rem;
  }
  .edu-school {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--brown-dark);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }
  .edu-major {
    font-size: 1rem;
    color: var(--brown-muted);
    margin-bottom: 1.5rem;
  }
  .gpa-display {
    display: flex; align-items: center; gap: 1.5rem;
  }
  .gpa-num {
    font-family: 'Playfair Display', serif;
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--amber);
    line-height: 1;
  }
  .gpa-label {
    font-size: 0.8rem;
    color: var(--brown-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .edu-courses {
    padding-left: 2rem;
    border-left: 2px solid var(--cream-dark);
  }
  .edu-courses h4 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 1.2rem;
  }
  .course-list { list-style: none; }
  .course-list li {
    font-size: 0.88rem;
    color: var(--brown-mid);
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--cream-dark);
    display: flex; align-items: center; gap: 0.6rem;
  }
  .course-list li:last-child { border-bottom: none; }
  .course-list li::before {
    content: '';
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--amber);
    flex-shrink: 0;
  }

  /* ── CONTACT FOOTER ── */
  .contact-section {
    background: linear-gradient(135deg, var(--brown-dark) 0%, #1A0A04 100%);
    padding: 100px 5%;
    text-align: center;
  }
  .contact-section .section-label { color: var(--amber-light); justify-content: center; }
  .contact-section .section-label::after { max-width: 40px; }
  .contact-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  .contact-title em { font-style: italic; color: var(--amber); }
  .contact-sub {
    font-size: 1rem;
    color: var(--brown-faint);
    max-width: 440px;
    margin: 0 auto 3rem;
    line-height: 1.7;
  }
  .contact-links {
    display: flex; justify-content: center; gap: 1.5rem;
